<Window x:Class="WeatherWallpaper.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weather Wallpaper - 设置"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="app.ico">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style TargetType="Button" x:Key="BtnStyle">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- URL -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="网页地址：" Style="{StaticResource LabelStyle}"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="UrlTextBox" FontSize="13" Padding="5,4"
                 VerticalContentAlignment="Center"/>

        <!-- Monitor Selection -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="显示器：" Style="{StaticResource LabelStyle}"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="MonitorComboBox" FontSize="13" Padding="5,4"
                  DisplayMemberPath="DisplayName"/>

        <!-- Audio -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="网页声音：" Style="{StaticResource LabelStyle}"/>
        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="AudioCheckBox" Content="启用声音" FontSize="13"
                  VerticalAlignment="Center"/>

        <!-- Auto Start -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="开机启动：" Style="{StaticResource LabelStyle}"/>
        <CheckBox Grid.Row="6" Grid.Column="1" x:Name="AutoStartCheckBox" Content="开机自动启动" FontSize="13"
                  VerticalAlignment="Center"/>

        <!-- Status -->
        <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" x:Name="StatusText" FontSize="12"
                   Foreground="Gray"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ApplyButton" Content="应用壁纸" Style="{StaticResource BtnStyle}"
                    Click="ApplyButton_Click" Margin="0,0,10,0"/>
            <Button x:Name="StopButton" Content="停止壁纸" Style="{StaticResource BtnStyle}"
                    Click="StopButton_Click" Margin="0,0,10,0"/>
            <Button Content="隐藏到托盘" Style="{StaticResource BtnStyle}"
                    Click="HideButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
